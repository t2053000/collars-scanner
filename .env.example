# ---- Telegram ----
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# ---- Schwab developer app ----
SCHWAB_APP_KEY=your_app_key
SCHWAB_APP_SECRET=your_app_secret
SCHWAB_REDIRECT_URI=https://127.0.0.1
SCHWAB_TOKEN_PATH=token.json
# On Railway, paste the ENTIRE token.json contents below instead of a path
# SCHWAB_TOKEN_JSON={"access_token":"...","refresh_token":"...",...}

# ---- GitHub (stores tickers.txt and whitelist.txt) ----
GITHUB_TOKEN=ghp_your_token
GITHUB_REPO=yourusername/collar-bot-data
GITHUB_TICKERS_PATH=tickers.txt
GITHUB_WHITELIST_PATH=whitelist.txt

LOG_LEVEL=INFO
